# --- Base de datos (Supabase Postgres) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vera

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api

# --- LLMs y generación de imágenes ---
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

# --- WhatsApp Cloud API (Meta Developers) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Publicador de campañas ---
# Opciones: mock_meta | whatsapp_broadcast
PUBLISHER_DEFAULT=mock_meta

# --- Entorno ---
ENV=development
