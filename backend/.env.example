# --- Base de datos (Supabase Postgres) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vera

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Generación de imágenes ---
REPLICATE_API_TOKEN=r8_...

# --- WhatsApp via Evolution API (instancia self-hosted del equipo) ---
EVOLUTION_API_URL=https://vera-evolutionapi.ada.huginn.info
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=Vera
EVOLUTION_FROM_NUMBER=5493876380350
WHATSAPP_WEBHOOK_SECRET=

# URL pública del frontend (usada en links de WhatsApp)
FRONTEND_BASE_URL=http://localhost:3000

# --- WhatsApp Cloud API (Meta Developers) — alternativa, no usada por default ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Shopify (development store + custom app token) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SHOP_DOMAIN=ana-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_...

# --- Meta Ads (development mode) ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_...

# --- Toggles de integración (rollback en caliente; ver CLAUDE.md §11) ---
USE_SHOPIFY_MOCK=false
USE_META_MOCK=false
USE_REPLICATE_MOCK=false
USE_OPENROUTER_MOCK=false
USE_WHATSAPP_MOCK=false

# --- Entorno ---
ENV=development
